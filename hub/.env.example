# ─── Postgres (Neon free tier: neon.tech) ───
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/setnel?sslmode=require

# ─── Telegram (reuse the same bot/channel as datum-monitor) ───
TELEGRAM_BOT_TOKEN=1234567890:xxx
TELEGRAM_CHAT_ID=-1003886406961

# ─── Private page login (one shared team password) ───
# Pick any strong string. Everyone on the team uses this to log in.
SETNEL_PASSWORD=change-me-to-something-strong
# Secret used to sign the login cookie. Any long random string.
SETNEL_SESSION_SECRET=another-long-random-string

# ─── Per-dashboard ingest secrets ───
# Each dashboard signs its events with a shared secret. Format:
#   SETNEL_DASHBOARD_SECRET_<DASHBOARD_ID>=<secret>
# Example for the Aave dashboard (id: aave):
SETNEL_DASHBOARD_SECRET_AAVE=shared-hmac-secret-for-aave
