# ─── Upstash Redis (free tier: upstash.com) ───
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# ─── Telegram bot (BotFather → /newbot, then add the bot to your channel/group) ───
# Get your chat ID: send a message to the bot, then curl
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=1234567890:xxx
TELEGRAM_CHAT_ID=-1001234567890

# ─── Resend (free tier: resend.com, needs a verified sender domain) ───
RESEND_API_KEY=re_xxx
EMAIL_FROM=alerts@datumlabs.xyz
EMAIL_TO=risk@datumlabs.xyz,founders@datumlabs.xyz

# ─── Runtime knobs ───
# Minutes between snapshot rows written to history (used for digest) — default 15
HISTORY_INTERVAL_MINUTES=15
# Hard timeout per dashboard request in ms — default 15000
REQUEST_TIMEOUT_MS=15000
# Cooldown before re-firing the same alert, minutes — default 60
ALERT_COOLDOWN_MINUTES=60
