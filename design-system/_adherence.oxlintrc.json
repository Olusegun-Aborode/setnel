{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/data/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "components/overlay/**",
              "ui_kits/console/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Geist|Geist Mono))/i]",
        "message": "Font not provided by the design system. Available: Geist, Geist Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|type|disabled|iconLeft|iconRight|as|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, type, disabled, iconLeft, iconRight, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|indeterminate|onChange|label|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, indeterminate, onChange, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|count|as|children|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: active, count, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Chip> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Command'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|group|hint|kbd|icon|run|key|ref|className|style|children)$/]",
        "message": "<Command> doesn't accept that prop. Declared props: id, label, group, hint, kbd, icon, run."
      },
      {
        "selector": "JSXOpeningElement[name.name='CoverageRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:risk|cells|key|ref|className|style|children)$/]",
        "message": "<CoverageRow> doesn't accept that prop. Declared props: risk, cells."
      },
      {
        "selector": "JSXOpeningElement[name.name='HeatStrip'] > JSXAttribute > JSXIdentifier[name!=/^(?:levels|checks|days|key|ref|className|style|children)$/]",
        "message": "<HeatStrip> doesn't accept that prop. Declared props: levels, checks, days."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|invalid|mono|size|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, invalid, mono, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<Input> size must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LiveIndicator'] > JSXAttribute > JSXIdentifier[name!=/^(?:live|seconds|onToggle|key|ref|className|style|children)$/]",
        "message": "<LiveIndicator> doesn't accept that prop. Declared props: live, seconds, onToggle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Menu'] > JSXAttribute > JSXIdentifier[name!=/^(?:trigger|children|align|side|key|ref|className|style|children)$/]",
        "message": "<Menu> doesn't accept that prop. Declared props: trigger, children, align, side."
      },
      {
        "selector": "JSXOpeningElement[name.name='Menu'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|right)$/]",
        "message": "<Menu> align must be one of 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Menu'] > JSXAttribute[name.name='side'] > Literal[value!=/^(?:bottom|top)$/]",
        "message": "<Menu> side must be one of 'bottom' | 'top'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricPoint'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|key|ref|className|style|children)$/]",
        "message": "<MetricPoint> doesn't accept that prop. Declared props: value."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricPointT'] > JSXAttribute > JSXIdentifier[name!=/^(?:t|value|label|key|ref|className|style|children)$/]",
        "message": "<MetricPointT> doesn't accept that prop. Declared props: t, value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|active|count|countTone|dot|as|key|ref|className|style|children)$/]",
        "message": "<NavItem> doesn't accept that prop. Declared props: icon, label, active, count, countTone, dot, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavItem'] > JSXAttribute[name.name='countTone'] > Literal[value!=/^(?:alert|muted)$/]",
        "message": "<NavItem> countTone must be one of 'alert' | 'muted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavItem'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<NavItem> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NowPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|count|key|ref|className|style|children)$/]",
        "message": "<NowPill> doesn't accept that prop. Declared props: level, count."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|note|aside|flush|divided|children|key|ref|className|style|children)$/]",
        "message": "<Panel> doesn't accept that prop. Declared props: title, note, aside, flush, divided, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SegmentOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sidebar'] > JSXAttribute > JSXIdentifier[name!=/^(?:brand|children|footer|key|ref|className|style|children)$/]",
        "message": "<Sidebar> doesn't accept that prop. Declared props: brand, children, footer."
      },
      {
        "selector": "JSXOpeningElement[name.name='SparkPoint'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|key|ref|className|style|children)$/]",
        "message": "<SparkPoint> doesn't accept that prop. Declared props: value."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|sub|tone|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: label, value, sub, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|showLabel|label|pulse|key|ref|className|style|children)$/]",
        "message": "<StatusDot> doesn't accept that prop. Declared props: status, showLabel, label, pulse."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|disabled|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange, label, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='TimeRangePreset'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<TimeRangePreset> doesn't accept that prop. Declared props: value, label."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
