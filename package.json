{
  "name": "datum-monitor",
  "version": "0.1.0",
  "private": true,
  "description": "Alert + digest system for Datum Labs dashboards",
  "type": "module",
  "scripts": {
    "check": "tsx src/index.ts check",
    "digest": "tsx src/index.ts digest",
    "warmup": "tsx src/index.ts warmup",
    "typecheck": "tsc --noEmit",
    "lint:config": "tsx src/index.ts validate-config"
  },
  "dependencies": {
    "@upstash/redis": "^1.34.3",
    "dotenv": "^16.4.5",
    "js-yaml": "^4.1.0",
    "resend": "^4.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
